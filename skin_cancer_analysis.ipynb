import pandas as pd
import os
from sklearn.model_selection import train_test_split

# 讀取 CSV 檔案
metadata_path = 'metadata.csv'
metadata = pd.read_csv(metadata_path)

# 檢查 images/ 資料夾中的每張圖片是否存在
image_folder = 'images/'
metadata['image_exists'] = metadata['img_id'].apply(lambda x: os.path.isfile(os.path.join(image_folder, x)))

# 顯示缺失的圖片
missing_images = metadata[~metadata['image_exists']]
print("缺失的圖片：")
print(missing_images)

# 切分資料集為訓練集與測試集
train_df, test_df = train_test_split(metadata, test_size=0.2, random_state=42)

# 儲存訓練集與測試集到 CSV 檔案
train_df.to_csv('train_set.csv', index=False)
test_df.to_csv('test_set.csv', index=False)

print("資料集已成功切分並儲存。")
