import pandas as pd
import torch
from torch.utils.data import Dataset
from torchvision import transforms
from PIL import Image

class SkinCancerDataset(Dataset):
    def __init__(self, csv_file, image_folder, transform=None):
        self.metadata = pd.read_csv(csv_file)
        self.image_folder = image_folder
        self.transform = transform

    def __len__(self):
        return len(self.metadata)

    def __getitem__(self, idx):
        img_id = self.metadata.iloc[idx]['img_id']
        img_path = f"{self.image_folder}/{img_id}"
        image = Image.open(img_path).convert('RGB')
        
        if self.transform:
            image = self.transform(image)

        # 提取數值特徵（年齡、性別等）
        numerical_features = self.metadata.iloc[idx][['Age', 'Gender']].values.astype(float)
        label = 1 if self.metadata.iloc[idx]['diagnostic'] == 'Melanoma' else 0

        return image, numerical_features, label
import torch.nn as nn
from torchvision.models import resnet18

class MultiModalModel(nn.Module):
    def __init__(self):
        super(MultiModalModel, self).__init__()
        
        # 使用預訓練的 ResNet18 提取影像特徵
        self.resnet = resnet18(pretrained=True)
        self.resnet.fc = nn.Identity()  # 去掉最後的全連接層
        
        # 數值特徵的全連接層
        self.fc_numerical = nn.Sequential(
            nn.Linear(2, 64),  # 假設有兩個數值特徵
            nn.ReLU(),
            nn.Linear(64, 32)
        )

        # 最終的全連接層
        self.fc_final = nn.Linear(512 + 32, 1)  # 512來自ResNet，32來自數值特徵

    def forward(self, image, numerical_features):
        image_features = self.resnet(image)
        numerical_features = self.fc_numerical(numerical_features)
        combined_features = torch.cat((image_features, numerical_features), dim=1)
        output = torch.sigmoid(self.fc_final(combined_features))
        return output
import torch.optim as optim
from torch.utils.data import DataLoader

# 設置超參數
batch_size = 32
num_epochs = 10
learning_rate = 0.001

# 數據增強轉換
transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
])

# 創建數據集和數據加載器
dataset = SkinCancerDataset('metadata.csv', 'images', transform)
dataloader = DataLoader(dataset, batch_size=batch_size, shuffle=True)

# 初始化模型、損失函數和優化器
model = MultiModalModel()
criterion = nn.BCELoss()
optimizer = optim.Adam(model.parameters(), lr=learning_rate)

# 訓練迴圈
for epoch in range(num_epochs):
    model.train()
    running_loss = 0.0
    
    for images, numerical_features, labels in dataloader:
        labels = labels.float().unsqueeze(1)  # 調整標籤形狀
        
        optimizer.zero_grad()
        outputs = model(images, numerical_features)
        loss = criterion(outputs, labels)
        loss.backward()
        optimizer.step()

        running_loss += loss.item()

    print(f"Epoch [{epoch + 1}/{num_epochs}], Loss: {running_loss / len(dataloader):.4f}")

print("訓練完成！")
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from sklearn.metrics import confusion_matrix, classification_report, roc_curve, auc

# 設置驗證集的數據加載器
val_dataset = SkinCancerDataset('val_metadata.csv', 'images', transform)
val_dataloader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False)

# 評估模型
model.eval()
all_labels = []
all_preds = []

with torch.no_grad():
    for images, numerical_features, labels in val_dataloader:
        labels = labels.float().unsqueeze(1)
        outputs = model(images, numerical_features)
        preds = (outputs > 0.5).float()  # 將預測值轉換為二元標籤

        all_labels.extend(labels.numpy())
        all_preds.extend(preds.numpy())

# 計算績效指標
all_labels = np.array(all_labels).flatten()
all_preds = np.array(all_preds).flatten()

accuracy = np.mean(all_labels == all_preds)
precision = np.sum((all_labels == 1) & (all_preds == 1)) / np.sum(all_preds == 1)
recall = np.sum((all_labels == 1) & (all_preds == 1)) / np.sum(all_labels == 1)
f1_score = 2 * (precision * recall) / (precision + recall)

print(f"Accuracy: {accuracy:.4f}")
print(f"Precision: {precision:.4f}")
print(f"Recall (Sensitivity): {recall:.4f}")
print(f"F1-score: {f1_score:.4f}")

# 繪製混淆矩陣
conf_matrix = confusion_matrix(all_labels, all_preds)
plt.figure(figsize=(8, 6))
sns.heatmap(conf_matrix, annot=True, fmt='d', cmap='Blues', xticklabels=['良性', '惡性'], yticklabels=['良性', '惡性'])
plt.title('混淆矩陣')
plt.xlabel('預測標籤')
plt.ylabel('實際標籤')
plt.show()

# 繪製 ROC 曲線
fpr, tpr, thresholds = roc_curve(all_labels, all_preds)
roc_auc = auc(fpr, tpr)

plt.figure(figsize=(8, 6))
plt.plot(fpr, tpr, color='blue', lw=2, label='ROC 曲線 (面積 = %0.2f)' % roc_auc)
plt.plot([0, 1], [0, 1], color='red', lw=2, linestyle='--')
plt.xlim([0.0, 1.0])
plt.ylim([0.0, 1.05])
plt.xlabel('假陽性率')
plt.ylabel('真陽性率')
plt.title('Receiver Operating Characteristic (ROC) Curve')
plt.legend(loc='lower right')
plt.show()
